# 복사하여 `.env` 로 만들고 실제 토큰 기입.
# `.env` 는 .gitignore 에 포함됨.

# --- Holdem 서버 (WS) ---
HOLDEM_WS_URL=ws://snn.it.kr:5051/ws
HOLDEM_API_TOKEN=YOUR_BOT_API_TOKEN_HERE
HOLDEM_BOT_NAME=YOUR_BOT_NAME_HERE

# --- 리더보드 자가 모니터링 (옵션, 의사결정 영향 없음) ---
# 미설정 시 leaderboard 폴링 task 자체 skip — 봇은 정상 동작.
# HOLDEM_RESULTS_BASE_URL=http://snn.it.kr:5051
# HOLDEM_SESSION_COOKIE=YOUR_HOLDEM_SESSION_COOKIE_HERE

# --- LLM 프록시 (OpenAI-compat) ---
HOLDEM_LLM_API_KEY=sk-cliproxy-xxxxxxxxxxxxxxxx
# HOLDEM_LLM_BASE_URL=http://localhost:8317/v1   # yaml 기본값 override 원할 때만

# --- 로그 ---
HOLDEM_LOG_LEVEL=INFO
