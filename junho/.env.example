# junho 봇 설정 예시 — 원본 packages/main_bot/.env 를 재현한 것.
# 실제 .env 에는 대회 API 토큰이 들어 있어 커밋하지 않았다 (.gitignore).
#
# 쓰는 법 2가지:
#  (1) 이 파일을 packages/main_bot/.env 로 복사 후 값 채우기 →  bash run.sh --env-file packages/main_bot/.env
#  (2) 아니면 run.sh 인자로 바로 주입          →  bash run.sh <WS_URL> <TOKEN> <NAME>
#
# 전체 필드/기본값 원천: packages/core/src/holdem_core/core/config.py 의 Settings

APP_NAME=holdem-main-bot
BOT_NAME=쫄보감별계산기                    # 대회 중 봇 표시 이름 (예시)
BOT_API_TOKEN=발급받은_토큰_여기          # 대시보드에서 봇 등록 시 발급
SERVER_WS_URL=ws://snn.it.kr:5051/ws       # 대회 서버 (로컬 테스트는 ws://localhost:5051/ws)
PORT=4000

# 부팅 시 자동 deploy (WS 인증만으로는 방 배정 안 됨 — BOT_REFERENCE §2.2).
# DASHBOARD_URL + BOT_ID 둘 다 있으면 부팅 때 1회 POST deploy. 비우면 대시보드에서 수동 deploy.
DASHBOARD_URL=
BOT_ID=0
AUTO_DEPLOY=true

# 관측/디버그
DEBUG=true
DEBUG_EVENTS=false                          # true(또는 --debug)면 .debug/room_*.jsonl 원본 이벤트 덤프
DEBUG_DIR=.debug                            # 상대 프로필/뻥카 prior/sqlite 가 쌓이는 곳
DECISION_LOG_PATH=logs/decisions.jsonl

# Streamlit 대시보드 (선택)
VIZ_ENABLED=false                           # true 로 켜면 봇 부팅 시 대시보드 서브프로세스도 기동
VIZ_PORT=8501
VIZ_DASHBOARD_PATH=tools/src/holdem_tools/viz/dashboard.py
